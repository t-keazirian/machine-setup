[user]
  # Name and email live in ~/.gitconfig.local (not committed — keep private).
  # Create that file with:
  #   [user]
  #     name = Your Name
  #     email = you@example.com

[include]
  path = ~/.gitconfig.local

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[push]
	autoSetupRemote = true

[color]
  ui = true

[commit]
  verbose = true

[core]
  autocrlf = input
	excludesfile = ~/.gitignore-global

[init]
	defaultBranch = main

[alias]
 # --- status / log / navigation ---
    st = status -sb
    lg = log --oneline --graph --decorate --all

    co = checkout
    sw = switch

 # "what changed"
    wc = log --pretty=format:"%C(yellow)%h%Creset %s %Cgreen(%cr) %Cblue[%an]" --name-status

 # detailed "what changed"
    wcd = log -p --pretty=format:"%C(yellow)%h%Creset %s %Cgreen(%cr) %Cblue[%an]"

 # stage all files, including deletions
    aa = add -A

 # commit and open window for message in vim
    c = commit -v

 # commit with a message in the command line
    cm = commit -m

 # Preview only: list local branches that would be deleted
    clean-branches-dry = "!f() { \
        base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##'); \
        base=${base:-main}; \
        echo \"[base=$base] would delete:\"; \
        git for-each-ref --format='%(refname:short)' --merged origin/$base refs/heads \
        | grep -vE \"\\b$base$|\\bmain$|\\bmaster$|\\bdevelop$\"; \
        }; f"

  # Delete local branches fully merged into the default branch (protect base/main/master/develop)
    clean-branches = "!f() { \
        base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##'); \
        base=${base:-main}; \
        git for-each-ref --format='%(refname:short)' --merged origin/$base refs/heads \
        | grep -vE \"\\b$base$|\\bmain$|\\bmaster$|\\bdevelop$\" \
        | while IFS= read -r b; do \
        [ -n \"$b\" ] && echo \"Deleting $b\" && git branch -D \"$b\"; \
        done; \
        }; f"

 # Preview only: show what fetch would do and which branches would be pruned
    clean-remote-dry = "!f() { \
        echo '== Dry-run fetch (no changes) =='; \
        git fetch --dry-run origin; \
        echo; \
        echo '== Dry-run prune (stale remote-tracking branches) =='; \
        git remote prune origin --dry-run; \
        }; f"

 # Actual cleanup
    clean-remote = "!git fetch --prune origin"

 # Remove all agent-generated worktrees under .claude/worktrees/, then prune stale refs
    wipe-agents = "!git worktree list | grep '.claude/worktrees' | awk '{print $1}' | xargs -I{} git worktree remove {} 2>/dev/null; git worktree prune; echo 'Agent worktrees cleaned'"

 # After merging a PR: switch to main, pull, clean agent worktrees, delete merged local branches
    done = "!git checkout main && git pull && git wipe-agents && git clean-branches"

