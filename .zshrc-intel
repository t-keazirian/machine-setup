# =========================
# Oh My Zsh + sane defaults
# =========================

export ZSH="$HOME/.oh-my-zsh"

# Use zsh path array with automatic de-dupe
typeset -U path PATH

# Core paths (Intel Homebrew first)
path=(/usr/local/sbin /usr/local/bin $path)

# Extra tools (Intel Homebrew)
path=(/usr/local/opt/vim/bin /usr/local/opt/python@3.13/bin $path)

# Personal scripts + local bin
path=("$HOME/Scripts" "$HOME/bin" $path)

# --- Completions BEFORE OMZ so compinit sees them ---
fpath=(~/.zsh/completions $fpath)

# NVM (must be defined before plugins load)
export NVM_DIR="$HOME/.nvm"
export NVM_AUTO_USE=true

# Theme & plugins (syntax-highlighting LAST)
ZSH_THEME="bira"
plugins=(
  git
  zsh-nvm
  zsh-autosuggestions
  colorize
  python
  pylint
  vundle
  web-search
  history
  jsontools
  macos
  sdk
  mvn
  direnv
  zsh-syntax-highlighting
)

# OMZ behavior
zstyle ':omz:update' mode reminder
ENABLE_CORRECTION="true"
COMPLETION_WAITING_DOTS="true"

# Load Oh My Zsh
source "$ZSH/oh-my-zsh.sh"

# ===================
# Aliases & utilities
# ===================

alias m='./mvnw'; compdef _mvn m

alias openz="vim ~/.zshrc"
alias openv="vim ~/.vimrc"
alias openg="vim ~/.gitconfig"
alias update="source ~/.zshrc"
alias ll="ls -aGl"

# Use Intel Homebrew Python
alias python='/usr/local/opt/python@3.13/bin/python3'

# Optional brew maintenance scripts (guarded)
if [ -x "$HOME/Scripts/brew-maintenance-simple.sh" ]; then
  alias brew-maint="$HOME/Scripts/brew-maintenance-simple.sh"
fi
if [ -x "$HOME/Scripts/brew-maintenance.sh" ]; then
  alias brew-maint-complex="$HOME/Scripts/brew-maintenance.sh"
fi

# =========
# App / env
# =========
export ERL_AFLAGS="-kernel shell_history enabled"
export SPRING_MAIN_BANNER_MODE=off

# =====
# pnpm
# =====
export PNPM_HOME="$HOME/Library/pnpm"
path=("$PNPM_HOME" $path)

# =====
# Java
# =====
if command -v brew >/dev/null 2>&1; then
  export JAVA_HOME="$(brew --prefix openjdk)/libexec/openjdk.jdk/Contents/Home"
  path=("$JAVA_HOME/bin" $path)
fi

# ==========================
# Rancher Desktop (optional)
# ==========================
if [ -d "$HOME/.rd/bin" ]; then
  path=("$HOME/.rd/bin" $path)
fi
